\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textit  {Left:} Observed score density (bars) versus the smooth polynomial counterfactual (dashed line), which was fit excluding the boundary region. The gap at scores 12--13 represents an excess of 13,734 inspections (+333\%, 95\% CI: [13,472, 13,996]). \textit  {Right:} Bootstrap distribution of the excess estimate under resampling. The near-zero width of the bootstrap distribution confirms the result is not sensitive to sampling variability.}}{5}{figure.caption.3}\protected@file@percent }
\newlabel{fig:mccrary}{{2}{5}{\textit {Left:} Observed score density (bars) versus the smooth polynomial counterfactual (dashed line), which was fit excluding the boundary region. The gap at scores 12--13 represents an excess of 13,734 inspections (+333\%, 95\% CI: [13,472, 13,996]). \textit {Right:} Bootstrap distribution of the excess estimate under resampling. The near-zero width of the bootstrap distribution confirms the result is not sensitive to sampling variability}{figure.caption.3}{}}
