\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Two-way ANOVA results. Balanced design with $n = 30$ per hypercategory-borough cell. Baselines: Bronx, African cuisine. Staten Island and Dietary Style excluded due to sparse cells.}}{14}{table.caption.14}\protected@file@percent }
\newlabel{tab:anova}{{3}{14}{Two-way ANOVA results. Balanced design with $n = 30$ per hypercategory-borough cell. Baselines: Bronx, African cuisine. Staten Island and Dietary Style excluded due to sparse cells}{table.caption.14}{}}
\@writefile{toc}{\contentsline {section}{\numberline {C}ANOVA Residual Diagnostics}{14}{appendix.C}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces ANOVA residual distribution (left) and normal Q-Q plot (right) for a sample of 3,000 observations. Residuals are clearly right-skewed, violating the normality assumption. This motivates our use of the Kruskal-Wallis test as a non-parametric robustness check ($H = 384.86$, $p < 0.001$), which reaches the same substantive conclusion.}}{14}{figure.caption.15}\protected@file@percent }
