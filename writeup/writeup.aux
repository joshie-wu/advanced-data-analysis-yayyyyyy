\newlabel{fig:agrade_boro}{{6}{9}{A-grade rate by year and borough (2022--2025), initial cycle inspections. Shaded bands are 95\% confidence intervals on the proportions. Manhattan leads throughout; Queens declines most sharply}{figure.caption.7}{}}
\@writefile{toc}{\contentsline {section}{\numberline {6}Conclusion}{9}{section.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces OLS regression coefficients for inspection score. Red bars indicate higher (worse) scores; green bars indicate lower (better) scores, relative to Bronx / African cuisine / year 2022 baselines. Error bars are 95\% confidence intervals. Year has a consistent, significant positive effect even after controlling for borough and cuisine.}}{10}{figure.caption.8}\protected@file@percent }
\newlabel{fig:ols_coefs}{{7}{10}{OLS regression coefficients for inspection score. Red bars indicate higher (worse) scores; green bars indicate lower (better) scores, relative to Bronx / African cuisine / year 2022 baselines. Error bars are 95\% confidence intervals. Year has a consistent, significant positive effect even after controlling for borough and cuisine}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Violation category rate by borough, as a percentage of all inspections in that borough. Darker shading indicates higher rates. Pest Control violations are most concentrated in the Bronx, while Cooling \& Refrigeration and Hot Holding violations show elevated rates in Manhattan and Queens, respectively.}}{11}{figure.caption.9}\protected@file@percent }
\newlabel{fig:heatmap}{{8}{11}{Violation category rate by borough, as a percentage of all inspections in that borough. Darker shading indicates higher rates. Pest Control violations are most concentrated in the Bronx, while Cooling \& Refrigeration and Hot Holding violations show elevated rates in Manhattan and Queens, respectively}{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Logistic regression coefficients for violation category, predicting A-grade probability. Red indicates negative association with earning an A (higher risk of failing); green indicates positive association. Model AUC $= 0.673$, controlling for borough, cuisine, and neighborhood income.}}{12}{figure.caption.10}\protected@file@percent }
\newlabel{fig:viol_coefs}{{9}{12}{Logistic regression coefficients for violation category, predicting A-grade probability. Red indicates negative association with earning an A (higher risk of failing); green indicates positive association. Model AUC $= 0.673$, controlling for borough, cuisine, and neighborhood income}{figure.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces \textit  {Left:} Distribution of next-inspection score by prior grade. \textit  {Center:} Mean score change from one inspection to the next, with 95\% confidence intervals. C-grade restaurants improve by 21 points on average; A-grade restaurants drift slightly worse. \textit  {Right:} Probability of earning an A on the next inspection by prior grade (A: 70\%, B: 56\%, C: 44\%).}}{12}{figure.caption.11}\protected@file@percent }
\newlabel{fig:trajectory}{{10}{12}{\textit {Left:} Distribution of next-inspection score by prior grade. \textit {Center:} Mean score change from one inspection to the next, with 95\% confidence intervals. C-grade restaurants improve by 21 points on average; A-grade restaurants drift slightly worse. \textit {Right:} Probability of earning an A on the next inspection by prior grade (A: 70\%, B: 56\%, C: 44\%)}{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces ROC curves for the three pre-inspection predictive models. All three cluster near AUC $= 0.60$, slightly above the diagonal (random guessing), confirming that borough, cuisine, and neighborhood variables provide limited predictive power regardless of model choice.}}{13}{figure.caption.13}\protected@file@percent }
\newlabel{fig:roc_compare}{{11}{13}{ROC curves for the three pre-inspection predictive models. All three cluster near AUC $= 0.60$, slightly above the diagonal (random guessing), confirming that borough, cuisine, and neighborhood variables provide limited predictive power regardless of model choice}{figure.caption.13}{}}
